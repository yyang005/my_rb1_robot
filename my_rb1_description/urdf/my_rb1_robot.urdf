<?xml version="1.0" ?>
<robot name="rb1_robot">

    <!-- Define materials for visualization -->
    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>

    <material name="gray">
        <color rgba="0.40 0.40 0.40 1"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <!-- Base footprint link -->
    <link name="base_footprint">
    </link>

    <!-- Joint connecting base_link and base_footprint -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_plate_joint" type="fixed">
        <!-- TO DO: Define axis (if needed) -->
        <!-- TO DO: Define origin -->
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <!-- TO DO: Define parent -->
        <parent link="base_footprint"/>
        <!-- TO DO: Define child -->
        <child link="base_link"/>
    </joint>

    <!-- Base link -->
    <link name="base_link">
        <!-- TO DO: Add visual tag -->
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.25" length="0.3"/>
            </geometry>
            <material name="blue" />
        </visual>
        <!-- TO DO: Add collision tag -->
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.25" length="0.3"/>
            </geometry>
        </collision>
        <!-- TO DO: Add inertial tag -->
        <inertial>
            <mass value="15"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <!--
            ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
                     iyy="${m*(3*r*r+h*h)/12}" iyz="0"
                     izz="${m*r*r/2}"
            -->
            <inertia ixx="0.346875" ixy="0" ixz="0"
                     iyy="0.346875" iyz="0"
                     izz="0.46875"
            />
        </inertial>
    </link>

    <!-- Left wheel link -->
    <link name="left_wheel">
        <!-- TO DO: Add visual tag -->
        <visual>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <geometry>
                <cylinder radius="0.025" length="0.01"/>
            </geometry>
            <material name="red" />
        </visual>
        <!-- TO DO: Add collision tag -->
        <collision>
            <geometry>
                <sphere radius="0.025" />
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0" />
        </collision>
        <!-- TO DO: Add inertial tag -->
        <inertial>
            <mass value="3"/>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <!-- ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
                     iyy="${m*(3*r*r+h*h)/12}" iyz="0"
                     izz="${m*r*r/2}"
            -->
            <inertia ixx="0.00049375" ixy="0" ixz="0"
                     iyy="0.00049375" iyz="0"
                     izz="0.0009375"
            />
        </inertial>
    </link>

    <!-- Joint connecting base_link and left_wheel -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_left_wheel_joint" type="continuous">
        <!-- TO DO: Define axis (if needed) -->
        <axis xyz="0 1 0" />
        <!-- TO DO: Define origin -->
        <origin xyz="0 -0.255 -0.15" rpy="0 0 0"/>
        <!-- TO DO: Define parent -->
        <parent link ="base_link"/>
        <!-- TO DO: Define child -->
        <child link ="left_wheel"/>
    </joint>

    <!-- Right wheel link -->
    <link name="right_wheel">
         <!-- TO DO: Add visual tag -->
        <visual>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <geometry>
                <cylinder radius="0.025" length="0.01"/>
            </geometry>
            <material name="red" />
        </visual>
        <!-- TO DO: Add collision tag -->
        <collision>
            <geometry>
                <sphere radius="0.025" />
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0" />
        </collision>
        <!-- TO DO: Add inertial tag -->
        <inertial>
            <mass value="3"/>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <!--inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
                     iyy="${m*(3*r*r+h*h)/12}" iyz="0"
                     izz="${m*r*r/2}"
            -->
            <inertia ixx="0.00049375" ixy="0" ixz="0"
                     iyy="0.00049375" iyz="0"
                     izz="0.0009375"
            />
        </inertial>
    </link>

    <!-- Joint connecting base_link and right_wheel -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_right_wheel_joint" type="continuous">
        <!-- TO DO: Define axis (if needed) -->
        <axis xyz="0 1 0" />
        <!-- TO DO: Define origin -->
        <origin xyz="0 0.255 -0.15" rpy="0 0 0"/>
        <!-- TO DO: Define parent -->
        <parent link ="base_link"/>
        <!-- TO DO: Define child -->
        <child link ="right_wheel"/>
    </joint>

    <!-- Front caster -->
    <link name="front_caster">
        <!-- TO DO: Add visual tag -->
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.025"/>
            </geometry>
            <material name="gray" />
        </visual>
        <!-- TO DO: Add collision tag -->
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.025"/>
            </geometry>
        </collision>
        <!-- TO DO: Add inertial tag -->
        <inertial>
            <mass value="2"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <!-- ixx="${m*r*r*2/5}" ixy="0" ixz="0"
                     iyy="${m*r*r*2/5}" iyz="0"
                     izz="${m*r*r*2/5}"-->
            <inertia ixx="0.0005" ixy="0" ixz="0"
                     iyy="0.0005" iyz="0"
                     izz="0.0005"/>
        </inertial>
    </link>

    <!-- Joint connecting base_link and front_caster -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_front_caster_joint" type="fixed">
        <!-- TO DO: Define axis (if needed) -->
        <!-- TO DO: Define origin -->
        <origin xyz="-0.1 0 -0.15" rpy="0 0 0"/>
        <!-- TO DO: Define parent -->
        <parent link ="base_link"/>
        <!-- TO DO: Define child -->
        <child link ="front_caster"/>
    </joint>

    <!-- Back caster -->
    <link name="back_caster">
        <!-- TO DO: Add visual tag -->
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.025"/>
            </geometry>
            <material name="gray" />
        </visual>
        <!-- TO DO: Add collision tag -->
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.025"/>
            </geometry>
        </collision>
        <!-- TO DO: Add inertial tag -->
        <inertial>
            <mass value="2"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.0005" ixy="0" ixz="0"
                     iyy="0.0005" iyz="0"
                     izz="0.0005"/>
        </inertial>
    </link>

    <!-- Joint connecting base_link and back_caster -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_back_caster_joint" type="fixed">
        <!-- TO DO: Define axis (if needed) -->
        <!-- TO DO: Define origin -->
        <origin xyz="0.1 0 -0.15" rpy="0 0 0"/>
        <!-- TO DO: Define parent -->
        <parent link ="base_link"/>
        <!-- TO DO: Define child -->
        <child link ="back_caster"/>
    </joint>

    <!-- Link representing the front laser scanner -->
    <!--For this robot, the laser is not visible, so we won't define a body for it. -->
    <link name="front_laser">
    </link>

    <!-- Joint connecting base_link and front_laser -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_front_laser_joint" type="fixed">
        <!-- TO DO: Define axis (if needed) -->
        <!-- TO DO: Define origin -->
        <origin xyz="0.25 0 0.075" rpy="3.14 0 0"/>
        <!-- TO DO: Define parent -->
        <parent link ="base_link"/>
        <!-- TO DO: Define child -->
        <child link ="front_laser"/>
    </joint>

</robot>